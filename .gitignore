# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Home Assistant
.HA_VERSION
.storage/
home-assistant.log*

# Trained model artifacts — large, regenerated by tools/train.py
custom_components/fuel_predictor_wa/models/*.pkl
custom_components/fuel_predictor_wa/models/*.npz
custom_components/fuel_predictor_wa/models/*.joblib
!custom_components/fuel_predictor_wa/models/.gitkeep

# Bulk history downloads — large, fetched by tools/download_history.py
data/
*.csv
!tests/**/*.csv

# Docs / build
site/
build/

# OS / editors
.DS_Store
.idea/
.vscode/
*.swp

# Local Claude settings (keep shared .claude/ tracked)
.claude/settings.local.json
